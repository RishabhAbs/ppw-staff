# ##############################################################################
# PPW Single Root Gitignore
# ##############################################################################

# Node / Dependencies
node_modules/
dist/
dist-ssr/
build/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime logs / startup scratch files
*.log
*.err
backend/_startup.*
backend/ppw-*.log

# Environment / Secret Files
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS Specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / Editor
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# Root Level Deployment & Temporary Files
/*.zip
/*.sql
/*.json
/*.ps1
/*.js
/*.txt
/*.png
/*.log
/*.postman_collection.json

# Specialized Folders
/cpanel_deploy/
/deploy/
/deployment_package/
/.agent/
/.gemini/
/android/

# White-list the essential directories
!/frontend/
!/backend/

# Essential files in root (if any)
!/.gitignore
!/README.md
!/docker-compose.yml
!/.htaccess_production
