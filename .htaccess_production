<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Proxy /api requests to the local Node.js backend running on PM2 port 3000
  RewriteRule ^api/(.*)$ http://127.0.0.1:3000/api/$1 [P,L]

  # Redirect all other frontend routes to React's index.html
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>